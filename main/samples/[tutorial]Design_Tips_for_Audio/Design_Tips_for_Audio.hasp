        "offline": {
          "amplitude_breakpoints_per_second": 40,
          "minimum_breakpoint_score": 1e-8,
          "amplitude": {
            "envelope_attack_time": 0.0001,
            "envelope_hold_time": 0.0015,
            "envelope_release_time": 0.1,
            "time_between_updates": 0.001,
            "rms_windowing_time": 0.0001
          },
          "frequency_breakpoints_per_second": 30,
          "frequency": {
            "frequency_max": 600,
            "frequency_min": 30,
            "output_min": 0,
            "output_max": 1
          },
          "emphasis_enabled": true,
          "emphasis": {
            "sensitivity_percent": 50,
            "peak_window_ms": 20,
            "minimum_rise": 0.05,
            "plateau_factor_percent": 25,
            "sharpness_min": 0,
            "sharpness_max": 1,
            "ducking_percent": 50
