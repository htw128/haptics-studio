pectrum":{"fft_size":1024,"overlap_factor":8,"centroid_lowpass_hz":1000},"minimum_breakpoint_score":1e-8,"amplitude":{"time_between_updates":0.001,"rms_windowing_time":0.0001,"envelope_attack_time":0.0001,"envelope_hold_time":0.0015,"envelope_release_time":0.1},"frequency_breakpoints_per_second":30,"frequency":{"frequency_min":30,"frequency_max":600,"output_min":0,"output_max":1},"emphasis_enabled":true,"emphasis":{"sensitivity_percent":50,"peak_window_ms":20,"minimum_rise":0.1,"plateau_factor_percent":25,"sharpness_min":null,"sharpness_max":null,"ducking_percent":50}}},"notes":"Before starting to edit the envelope, it is good to know that Haptics Studio supports two distinct workflows for creating haptic effects, each suited to different use cases.\n\n**1. Design from Audio**\nStart by importing an audio file. Haptics Studio automatically analyzes the signal to generate an amplitude and frequency envelope.\n\n**2. Freeform Haptics**\nStart from scratch by drawing envelopes using the Pen tool.\n\nThis approach gives you full creative control and is perfect for prototyping gestures, UI interactions, or custom effects without needing an audio source.\n\n/newpage\nWhether you're designing haptics from an audio file or drawing from scratch, you can refine your work through breakpoint editing.\n\n<p align=\"center\"><img width=\"100%\" src=\"media://assets/breakpoints.png\"/></p>This gives you precise control over how the amplitude and frequency envelopes evolve over time.\n\nClick on the envelope to view the breakpoints.\n\n/newpage\n\n<p align=\"center\"><video width=\"100%\" src=\"media://assets/points.mp4\" autoplay loop/></p>**Move Points**\nSelect one or more breakpoints, then click and drag to reposition them along the envelope. For more precise control use the input fields in the Design tab.\n\n**Add Points**\nTo add points use the Pen tool from the Tool Bar.\n\n**Delete Points**\nSelect one or more points and press the Delete key to remove them.\n\n/newpage\n\nTake a moment to explore breakpoint editing on your own.\n \nTry creating a more complex haptic shape like the example below. \n\nPlay around, experiment and have some fun!\n<p align=\"center\"> <img width=\"100%\" src=\"media://./assets/trythis.png\" /> </p>\n\n\n\n","lastUpdate":1750685202828,"haptic":{"version":{"major":1,"minor":0,"patch":0},"metadata":{"editor":"Meta Haptics Studio 2.0.0-beta.9","source":"Silence.wav","project":"Editing the Envelope","tags":[],"description":""},"signals":{"continuous":{"envelopes":{"amplitude":[{"time":0,"amplitude":0.00007626055},{"time":1,"amplitude":0.8416077684223466},{"time":2,"amplitude":0.000117901014}],"frequency":[{"time":0,"frequency":0},{"time":2.01,"frequency":0}]}}}}},{"clipId":"dcc1ceff-a88a-434d-977c-a83431ea0a4d","name":"Detailed Modulation","audioAsset":{"filename":"Complex.wav","path":"Complex.wav","channels":1},"waveform":{"envelope":[{"time":0.005,"amplitude":0.0037744185},{"time":0.01,"amplitude":0.03544946},{"time":0.015,"amplitude":0.03524429},{"time":0.02,"amplitude":0.039932236},{"time":0.025,"amplitude":0.042887732},{"time":0.03,"amplitude":0.049347468},{"time":0.035,"amplitude":0.042341977},{"time":0.04,"amplitude":0.0416003},{"time":0.044999998,"amplitude":0.08874396},{"time":0.05,"amplitude":0.095190585},{"time":0.055,"amplitude":0.082709074},{"time":0.06,"amplitude":0.09083882},{"time":0.065,"amplitude":0.08085926},{"time":0.07,"amplitude":0.06939019},{"time":0.074999996,"amplitude":0.060258314},{"time":0.08,"amplitude":0.052123602},{"time":0.085,"amplitude":0.045135573},{"time":0.090020835,"amplitude":0.048000596},{"time":0.09502083,"amplitude":0.045156248},{"time":0.10002083,"amplitude":0.045512103},{"time":0.10502083,"amplitude":0.03933177},{"time":0.11002083,"amplitude":0.033638768},{"time":0.115020834,"amplitude":0.02882386},{"time":0.12002083,"amplitude":0.02487832},{"time":0.12502083,"amplitude":0.027638415},{"time":0.13002083,"amplitude":0.028594937},{"time":0.135,"amplitude":0.026200749},{"