core":1e-8,"amplitude":{"time_between_updates":0.001,"rms_windowing_time":0.0001,"envelope_attack_time":0.0001,"envelope_hold_time":0.0015,"envelope_release_time":0.1},"frequency_breakpoints_per_second":30,"frequency":{"frequency_min":30,"frequency_max":600,"output_min":0,"output_max":1},"emphasis_enabled":true,"emphasis":{"sensitivity_percent":50,"peak_window_ms":20,"minimum_rise":0.1,"plateau_factor_percent":25,"sharpness_min":null,"sharpness_max":null,"ducking_percent":50}}},"notes":"There are three fundamental ways to control the motor that produces vibration feedback:\n\n**Amplitude:** \nThe strength or intensity of the vibration.\n\n**Frequency:** \nThe speed or pitch of the vibration.\n\n**Emphasis:** \nThe accentuation of specific moments in time.\n\n/newpage\n\nLet’s start with Amplitude.\n\nThis refers to how strongly the motor moves back and forth, modulating the force of the vibration. \n\nHigher amplitude results in more intense feedback, while lower amplitude feels softer and more subtle.\n\nWe control amplitude using the amplitude envelope, shown in blue.\n\nIn this clip, we’re using a square-shaped envelope with a strong, constant intensity.\n\nPress the B and Y buttons on your Quest controllers to audition this haptic.\n\n<p align=\"center\">\n<img width=\"70%\" src=\"media://./assets/buttonB.png\" />\n","lastUpdate":1750684562789,"haptic":{"version":{"major":1,"minor":0,"patch":0},"metadata":{"editor":"Haptic Studio","source":"Silence.wav","project":"Strong Vibration","tags":[],"description":""},"signals":{"continuous":{"envelopes":{"amplitude":[{"time":0,"amplitude":0.00007626055},{"time":0.0010204081,"amplitude":0.00007626055},{"time":0.0475742503466559,"amplitude":0.00007723076882384402},{"time":0.047579250346655895,"amplitude":1},{"time":1.900661376520193,"amplitude":1},{"time":1.9006663765201932,"amplitude":2.0816681711721685e-16},{"time":2,"amplitude":0.000117901014}],"frequency":[{"time":0,"frequency":0},{"time":2.01,"frequency":0}]}}}}},{"c