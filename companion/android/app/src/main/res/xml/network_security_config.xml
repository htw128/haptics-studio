<!--
  This sample connects to the Haptics Studio desktop over an unencrypted Socket.IO
  connection (ws://<ip>:9999) on the local network, so cleartext traffic must be
  permitted. A production app should restrict this to the specific hosts it talks to
  or use TLS instead.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
